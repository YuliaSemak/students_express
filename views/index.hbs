<!--view table of sloniki-->
<table>
    <thead>
    <tr>
        <th scope="col">ID</th>
        <th scope="col">USERNAME</th>
        <th scope="col">CREATED AT</th>
        
    </tr>
    </thead>
    <tbody>
    {{#each sloniki}}
        <tr>
            <th scope="row">{{@index}}</th>
            <td>{{this.username}}</td>
            <td>{{this.created_at}}</td>
        </tr>
    {{/each}}
    </tbody>
</table>